# IAQverse - Configuration Production
# Copier ce fichier vers .env.prod et remplir les valeurs

# Application
APP_NAME=IAQverse
APP_VERSION=2.0.0
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# InfluxDB Configuration
INFLUXDB_ENABLED=true
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme-influxdb-token
INFLUXDB_ORG=iaqverse
INFLUXDB_BUCKET=iaq_data
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=changeme-strong-password

# WebSocket
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# MQTT Configuration (Optional)
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=iaqverse

# ML Services
ML_PREDICTOR_INTERVAL=600
ML_TRAINER_INTERVAL=86400
ML_FORECAST_MINUTES=30
RETRAIN_INTERVAL=12
ML_SCHEDULER_ENABLED=true

# Data Retention
DATA_RETENTION_DAYS=90
MAX_MEMORY_RECORDS=10000

# Supabase Configuration
SUPABASE_ENABLED=true
SUPABASE_URL=changeme-supabase-url
SUPABASE_KEY=changeme-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=changeme-supabase-service-role-key
